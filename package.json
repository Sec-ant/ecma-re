{
  "name": "ecma-re",
  "version": "0.1.0",
  "description": "Transpile Python regex patterns into ECMAScript RegExp objects",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7",
  "main": "./dist/ecma-re.cjs",
  "module": "./dist/ecma-re.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/ecma-re.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/ecma-re.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sec-ant/ecma-re.git"
  },
  "homepage": "https://github.com/Sec-ant/ecma-re",
  "bugs": {
    "url": "https://github.com/Sec-ant/ecma-re/issues"
  },
  "keywords": [
    "python",
    "regex",
    "regexp",
    "regular-expression",
    "transpiler",
    "parser",
    "unicode",
    "esmodule"
  ],
  "author": {
    "name": "Ze-Zheng Wu"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite dev -c demo/vite.config.ts --open",
    "demo:build": "vite build -c demo/vite.config.ts",
    "update-hooks": "simple-git-hooks",
    "lint": "biome lint .",
    "type-check": "tsc --noEmit --emitDeclarationOnly false",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "clear:dist": "rimraf dist",
    "prebuild": "pnpm -s check && pnpm -s type-check && pnpm -s clear:dist",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "prepublishOnly": "pnpm -s build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.2",
    "@vitest/ui": "4.1.4",
    "lint-staged": "^16.4.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "simple-git-hooks"
    ]
  }
}
